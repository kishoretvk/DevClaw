    "# Generate output comparison\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"GENERATED TEXT COMPARISON\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "print(\"\\n--- BASELINE OUTPUT ---\")\n",
    "print(baseline_results['text'])\n",
    "\n",
    "print(\"\\n--- CSA OUTPUT ---\")\n",
